# ESPHome Secrets Configuration Template
# Copy this file to esphome/secrets.yaml and fill in your values

# WiFi credentials
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Home Assistant API encryption key
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
api_encryption_key: "0123456789abcdef0123456789abcdef"

# OTA update password
ota_password: "esphome"

# Home Assistant host (optional, for debugging)
ha_api_password: "long-lived-access-token"
